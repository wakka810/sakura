{
  "name": "sakura-browser-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:linux": "cargo build --workspace",
    "build:wasm": "node tools/build-wasm.mjs",
    "serve": "node tools/local-server.mjs",
    "test:browser-audio": "node tests/audio-mixer.mjs",
    "test:browser-catalog": "node tests/local-catalog.mjs",
    "test:browser-graph": "node tests/graph-renderer.mjs",
    "test:browser-input": "node tests/input-controller.mjs",
    "test:browser-runtime-input": "node tests/runtime-session-input-bridge.mjs",
    "test:browser-scenario-backlog": "node tests/scenario-backlog.mjs",
    "test:browser-scenario-config-window": "node tests/scenario-config-window.mjs",
    "test:browser-scenario-filter": "node tests/scenario-filter.mjs",
    "test:browser-scenario-message-window": "node tests/scenario-message-window.mjs",
    "test:browser-scenario-routes": "node tests/scenario-routes.mjs",
    "test:browser-scenario-shake": "node tests/scenario-shake.mjs",
    "test:browser-scenario-sprites": "node tests/scenario-sprites.mjs",
    "test:browser-scenario-userdata-window": "node tests/scenario-userdata-window.mjs",
    "test:browser-state": "node tests/runtime-state-export.mjs",
    "test:local-server": "node tests/local-server.mjs",
    "test:rust": "cargo test --workspace",
    "test:wasm-movie": "node tests/movie-decoder.mjs",
    "test:wasm-session": "node tests/session-handle-smoke.mjs",
    "test:wasm": "node tests/wasm-smoke.mjs",
    "test": "npm run test:rust && npm run build:wasm && npm run test:wasm && npm run test:wasm-movie && npm run test:wasm-session && npm run test:browser-catalog && npm run test:browser-input && npm run test:browser-runtime-input && npm run test:browser-state && npm run test:browser-audio && npm run test:browser-graph && npm run test:browser-scenario-backlog && npm run test:browser-scenario-config-window && npm run test:browser-scenario-filter && npm run test:browser-scenario-message-window && npm run test:browser-scenario-routes && npm run test:browser-scenario-shake && npm run test:browser-scenario-sprites && npm run test:browser-scenario-userdata-window && npm run test:local-server",
    "dev": "npx nodemon --watch . --ext js,mjs,json,html,css,wasm,rs tools/local-server.mjs"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "playwright": "1.60.0"
  },
  "dependencies": {
    "pl_mpeg.c": "1.2025.5"
  }
